# ============================================================
# Quran Foundation credentials
# Request at: https://api-docs.quran.foundation/request-access
# ============================================================
#
# You'll receive two credential sets. HifzGuard uses both:
#
#   Pre-Production (Test)  → use for USER APIs (bookmarks, streaks)
#   Production (Live)      → use for CONTENT APIs (full Quran)
#
# Pre-live has all features enabled but only a subset of verses.
# Production has the full Quran but user features are off by default.
# ============================================================

# ------- Content API: PRODUCTION credentials -------
QURAN_CLIENT_ID=your_production_client_id
QURAN_CLIENT_SECRET=your_production_client_secret
QURAN_AUTH_BASE_URL=https://oauth2.quran.foundation
QURAN_CONTENT_BASE_URL=https://apis.quran.foundation

# ------- User API: PRE-LIVE credentials -------
QURAN_USER_CLIENT_ID=your_prelive_client_id
QURAN_USER_CLIENT_SECRET=your_prelive_client_secret
QURAN_USER_AUTH_BASE_URL=https://prelive-oauth2.quran.foundation

# Same value as QURAN_USER_CLIENT_ID — exposed to browser for user OAuth redirect
NEXT_PUBLIC_QURAN_CLIENT_ID=your_prelive_client_id

# Public app URL — used for OAuth2 redirect_uri
NEXT_PUBLIC_APP_URL=http://localhost:3000
